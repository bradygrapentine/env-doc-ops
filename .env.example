# Auth.js — required.
AUTH_SECRET=replace-me

# SQLite path (optional; defaults to ./data/envdocos.db).
# ENVDOCOS_DB_PATH=./data/envdocos.db

# Email (Resend). Required to actually send verification + reset emails in
# production. In development you can leave these blank — the wrapper logs a
# warning and silently no-ops, so signup/forgot-password keep working.
RESEND_API_KEY=
EMAIL_FROM="EnvDocOS Traffic <noreply@example.com>"

# Set to "memory" to capture emails in an in-memory array (used by tests + E2E).
# Tests automatically force this on via NODE_ENV=test.
# EMAIL_SINK=memory
